    { "permission": "bash", "pattern": "cat *", "action": "allow" },
    { "permission": "bash", "pattern": "head *", "action": "allow" },
    { "permission": "bash", "pattern": "tail *", "action": "allow" },
    { "permission": "bash", "pattern": "less *", "action": "allow" },
    { "permission": "bash", "pattern": "more *", "action": "allow" },
    { "permission": "bash", "pattern": "bat *", "action": "allow" },
    { "permission": "bash", "pattern": "grep *", "action": "allow" },
    { "permission": "bash", "pattern": "rg *", "action": "allow" },
    { "permission": "bash", "pattern": "find *", "action": "allow" },
    { "permission": "bash", "pattern": "fd *", "action": "allow" },
    { "permission": "bash", "pattern": "awk *", "action": "allow" },
    { "permission": "bash", "pattern": "sed -n *", "action": "allow" },
    { "permission": "bash", "pattern": "ls *", "action": "allow" },
    { "permission": "bash", "pattern": "tree *", "action": "allow" },
    { "permission": "bash", "pattern": "exa *", "action": "allow" },
    { "permission": "bash", "pattern": "stat *", "action": "allow" },
