    { "permission": "bash", "pattern": "git log *", "action": "allow" },
    { "permission": "bash", "pattern": "git diff *", "action": "allow" },
    { "permission": "bash", "pattern": "git show *", "action": "allow" },
    { "permission": "bash", "pattern": "git branch *", "action": "allow" },
    { "permission": "bash", "pattern": "git remote *", "action": "allow" },
    { "permission": "bash", "pattern": "git config --get *", "action": "allow" },
    { "permission": "bash", "pattern": "git ls-remote *", "action": "allow" },
    { "permission": "bash", "pattern": "git ls-files *", "action": "allow" },
    { "permission": "bash", "pattern": "git ls-tree *", "action": "allow" },
    { "permission": "bash", "pattern": "npm list *", "action": "allow" },
    { "permission": "bash", "pattern": "npm view *", "action": "allow" },
    { "permission": "bash", "pattern": "npm info *", "action": "allow" },
    { "permission": "bash", "pattern": "npm outdated *", "action": "allow" },
    { "permission": "bash", "pattern": "yarn list *", "action": "allow" },
    { "permission": "bash", "pattern": "yarn info *", "action": "allow" },
    { "permission": "bash", "pattern": "yarn why *", "action": "allow" },
    { "permission": "bash", "pattern": "echo *", "action": "allow" },
    { "permission": "bash", "pattern": "wc *", "action": "allow" },
    { "permission": "bash", "pattern": "sort *", "action": "allow" },
    { "permission": "bash", "pattern": "uniq *", "action": "allow" },
    { "permission": "bash", "pattern": "cut *", "action": "allow" },
    { "permission": "bash", "pattern": "tr *", "action": "allow" },
    { "permission": "bash", "pattern": "rev *", "action": "allow" },
    { "permission": "bash", "pattern": "tee *", "action": "allow" },
    { "permission": "bash", "pattern": "xargs *", "action": "allow" },
    { "permission": "bash", "pattern": "curl *", "action": "allow" },
    { "permission": "bash", "pattern": "wget *", "action": "allow" },
    { "permission": "bash", "pattern": "env", "action": "allow" },
    { "permission": "bash", "pattern": "printenv *", "action": "allow" },
    { "permission": "bash", "pattern": "node -e *", "action": "allow" },
    { "permission": "bash", "pattern": "bun -e *", "action": "allow" },
    { "permission": "read", "pattern": "**", "action": "allow", "modes": ["build", "plan"] },
    { "permission": "edit", "pattern": "**", "action": "ask" }
