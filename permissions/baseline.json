    { "permission": "bash", "pattern": "df *", "action": "allow" },
    { "permission": "bash", "pattern": "pwd", "action": "allow" },
    { "permission": "bash", "pattern": "which *", "action": "allow" },
    { "permission": "bash", "pattern": "whereis *", "action": "allow" },
    { "permission": "bash", "pattern": "type *", "action": "allow" },
    { "permission": "bash", "pattern": "whoami", "action": "allow" },
    { "permission": "bash", "pattern": "uname *", "action": "allow" },
    { "permission": "bash", "pattern": "date", "action": "allow" },
    { "permission": "bash", "pattern": "uptime", "action": "allow" },
    { "permission": "bash", "pattern": "ps *", "action": "allow" },
    { "permission": "bash", "pattern": "top", "action": "allow" },
    { "permission": "bash", "pattern": "htop", "action": "allow" },
    { "permission": "bash", "pattern": "free", "action": "allow" },
